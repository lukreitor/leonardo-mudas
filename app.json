{
  "expo": {
    "name": "Leonardo Mudas",
    "slug": "leonardo-mudas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "leonardomudas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.lukreitor.leonardomudas",
      "infoPlist": {
        "NSCameraUsageDescription": "Tirar fotos e gravar vídeos das visitas às fazendas.",
        "NSMicrophoneUsageDescription": "Gravar áudios das observações de visita.",
        "NSPhotoLibraryUsageDescription": "Salvar fotos da galeria como anotação.",
        "NSLocationWhenInUseUsageDescription": "Sugerir fazenda próxima quando você chegar."
      }
    },
    "android": {
      "package": "br.lukreitor.leonardomudas",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1A3A2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5F0E6",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#0E1B14"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita a câmera para capturar fotos e vídeos das visitas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita o acesso à galeria para anexar fotos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permita Face ID para login rápido."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita localização para sugerir fazendas próximas.",
          "locationWhenInUsePermission": "Permita localização para sugerir fazendas próximas."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4A7C59"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "5678d758-48bb-4610-8a26-aaed774ff438"
      },
      "router": {}
    },
    "owner": "dulloo"
  }
}
